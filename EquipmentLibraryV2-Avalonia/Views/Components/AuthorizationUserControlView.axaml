<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:vm="using:EquipmentLibraryV2_Avalonia.ViewModels.Components"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:AuthorizationUserControlViewModel"
             x:Class="EquipmentLibraryV2_Avalonia.Views.Components.AuthorizationUserControlView">
    
    <UserControl.Styles>
		<StyleInclude Source="/Styles/AuthorizationStyles.axaml"/>
	</UserControl.Styles>
    
    <Grid ColumnDefinitions="Auto, *">
        <Border Grid.Column="0" 
                Width="280" 
                Classes="SidePanel"
                Padding="25, 40, 25, 25">
        
            <StackPanel Spacing="20">
                <StackPanel Spacing="5" Margin="0,0,0,10">
                    <TextBlock Text="Welcome back" 
                               Foreground="White" 
                               FontSize="24" 
                               FontWeight="Bold"/>
                    <TextBlock Text="Please sign in to continue" 
                               Foreground="#666" 
                               FontSize="13"/>
                </StackPanel>

                <TextBlock Text="{Binding MessageError}" 
                           Classes="ErrorMessage"
                           IsVisible="{Binding MessageError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <StackPanel Spacing="15">
                    <StackPanel>
                        <TextBlock Text="Login" Classes="FieldLabel"/>
                        <TextBox Text="{Binding Login}" 
                                 PlaceholderText="Your login..." 
                                 Classes="ModernInput"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Password" Classes="FieldLabel"/>
                        <TextBox Text="{Binding Password}" 
                                 PasswordChar="•" 
                                 PlaceholderText="••••••••" 
                                 Classes="ModernInput"/>
                    </StackPanel>
                </StackPanel>

                <Button Command="{Binding AuthorizationCommand}" 
                        IsEnabled="{Binding IsActiveConfirmButton}" 
                        Content="Sign In" 
                        Classes="PrimaryButton"
                        Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" 
                Background="Black" 
                Opacity="0.4" 
                PointerPressed="CloseAuthorization_PointerPressed">
        </Border>
    </Grid>
</UserControl>
