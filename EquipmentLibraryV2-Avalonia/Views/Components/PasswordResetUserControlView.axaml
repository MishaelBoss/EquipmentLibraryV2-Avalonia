<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EquipmentLibraryV2_Avalonia.ViewModels.Components"
             x:DataType="vm:PasswordResetUserControlViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="EquipmentLibraryV2_Avalonia.Views.Components.PasswordResetUserControlView">
    
    <UserControl.Styles>
        <StyleInclude Source="/Styles/ModernStyles.axaml"/>
    </UserControl.Styles>
    
    <Grid>
        <Border Background="#1A1A1A" Opacity="0.8"/>
    
        <Border Classes="modernBorder" Width="480" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Margin="25" Spacing="16">
            
                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                    <Grid Grid.Column="0" RowDefinitions="Auto, Auto">
                        <TextBlock Grid.Row="0" Foreground="White" FontSize="22">
                            <Run Text="Password reset: " FontWeight="SemiBold"/>
                            <Run Text="{Binding Login}" FontWeight="Bold" Foreground="LightBlue"/>
                        </TextBlock>
                        <TextBlock Grid.Row="1"
                                   Text="Запомните пароль" 
                                   Foreground="#BFBFBF" 
                                   FontSize="16"/>
                    </Grid>
                    <Button Grid.Column="1" Command="{Binding CloseCommand}" Classes="modernClosed">
                        <Panel Width="18" Height="18">
                            <Image Classes="normal" Source="{SvgImage /Assets/close.svg}" Width="18" Height="18"/>
                            <Image Classes="hover" Source="{SvgImage /Assets/close_dark.svg}" Width="18" Height="18"/>
                        </Panel>
                    </Button>
                </Grid>
                
                <StackPanel IsVisible="{Binding !IsStatus}">
                    <Button Classes="modernPrimary" Height="45"
                            Command="{Binding GenerateCommand}"
                            Margin="0,10,0,0"
                            IsEnabled="{Binding IsActiveConfirmButton}">
                        <StackPanel Spacing="5" Orientation="Horizontal">
                            <TextBlock Text="Generate"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            
                <StackPanel IsVisible="{Binding IsStatus}">
                    <Button Command="{Binding CopyPasswordCommand}" 
                            Background="#3A3A3A" CornerRadius="6" Height="60" HorizontalAlignment="Stretch">
                        <TextBlock Text="{Binding GeneratedPassword}" 
                                   VerticalAlignment="Center" HorizontalAlignment="Center" 
                                   FontSize="36" Foreground="White" FontWeight="UltraBold"
                                   Classes="modernInput"/>
                    </Button>

                    <Button Classes="modernPrimary" Height="45"
                            Command="{Binding CloseAndCopyPasswordCommand}"
                            Margin="0,10,0,0"
                            IsEnabled="{Binding IsActiveConfirmButton}">
                        <StackPanel Spacing="5" Orientation="Horizontal">
                            <TextBlock Text="Close and Copy Password"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
