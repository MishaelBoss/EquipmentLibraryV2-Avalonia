<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:vm="using:EquipmentLibraryV2_Avalonia.ViewModels.Components"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:ConfirmDeleteUserControlViewModel"
             x:Class="EquipmentLibraryV2_Avalonia.Views.Components.ConfirmDeleteUserControlView">

    <UserControl.Styles>
		<StyleInclude Source="/Styles/AddUserFormStyles.axaml"/>
	</UserControl.Styles>

    <Grid>
        <Border Background="#1A1A1A" Opacity="0.8"/>
    
        <Border Classes="FormCard" Width="480" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Margin="25" Spacing="16">
            
                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                    <TextBlock Text="{Binding Text}" Foreground="White" FontSize="22" FontWeight="SemiBold"/>
                    <Button Grid.Column="1" Command="{Binding CloseCommand}" Background="Transparent">
                        <Image Source="/Assets/close-64.png" Width="18" Height="18"/>
                    </Button>
                </Grid>

                <Button Classes="PrimaryButton" 
                        Command="{Binding ConfirmCommand}" 
                        Content="Confirm"
                        Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
