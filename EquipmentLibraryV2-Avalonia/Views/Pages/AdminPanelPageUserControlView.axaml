<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:vm="using:EquipmentLibraryV2_Avalonia.ViewModels.Pages"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:AdminPanelPageUserControlViewModel"
             x:Class="EquipmentLibraryV2_Avalonia.Views.Pages.AdminPanelPageUserControlView">
	
	<UserControl.Styles>
		<StyleInclude Source="/Styles/UserCardStyles.axaml"/>
	</UserControl.Styles>

	<Grid>
		<Grid	Margin="10" 
				RowDefinitions="Auto, Auto, *" 
				ZIndex="2">

			<Grid	Grid.Row="0" 
					HorizontalAlignment="Right" 
					VerticalAlignment="Top" 
					ColumnDefinitions="Auto, Auto">
				<StackPanel		Grid.Column="1"
		  						Orientation="Horizontal"
		  						HorizontalAlignment="Center"
		  						Margin="10,0,0,0">

		  			<Button HorizontalAlignment="Right"
		  					VerticalAlignment="Top"
		  					Width="32"
		  					Height="32"
		  					ToolTip.Tip="Adds">
		  				<Image Source="/Assets/add-64.png"/>
		  				<Button.Flyout>
		  					<Flyout Placement="Bottom">
		  						<ListBox>
									<Button Command="{Binding AddUserCommand}"
		  									VerticalAlignment="Stretch"
		  									HorizontalAlignment="Stretch"
		  									Content="Add user"/>
		  						</ListBox>
		  					</Flyout>
		  				</Button.Flyout>
		  			</Button>
		  		</StackPanel>
			</Grid>
		</Grid>

        <TabControl Margin="5">
			<TabItem Header="Users" Foreground="White">
				<Grid RowDefinitions="Auto, Auto, *">
					<Grid Grid.Row="0" 
						   HorizontalAlignment="Center" 
						   VerticalAlignment="Top" 
						   ColumnDefinitions="Auto, Auto">
						<Border Grid.Column="0"
								CornerRadius="20"
						        Background="#8E9198"
						        Padding="20,12">
							<StackPanel Orientation="Vertical"
							            HorizontalAlignment="Center"
							            Spacing="8">
								<TextBox Width="280"
								         Height="38"
								         PlaceholderText="Search"
								         HorizontalAlignment="Center"
								         VerticalContentAlignment="Center"
								         Text="{Binding SearchText, Mode=TwoWay}"
								         Margin="0"
								         CornerRadius="14"
								         BorderThickness="1.5"
								         BorderBrush="#B0B3B8"
								         FontSize="15"/>
								<StackPanel Orientation="Horizontal"
								            HorizontalAlignment="Center"
								            Spacing="15">
									<StackPanel Orientation="Horizontal" 
									            Spacing="10">
										<CheckBox Content="Активные" 
										          IsChecked="{Binding ShowActiveUsers}"/>
										<CheckBox Content="Неактивные" 
										          IsChecked="{Binding ShowInactiveUsers}"/>
									</StackPanel>
									<Button Content="Сбросить"
									        VerticalContentAlignment="Center"
									        HorizontalContentAlignment="Center"
									        Foreground="White"
									        Background="#3A3A3A"
									        BorderBrush="#555"
									        BorderThickness="1"
									        CornerRadius="6"
									        Command="{Binding ResetFiltersCommand}"
									        Height="30"
									        Width="100"
									        FontSize="13"
									        FontWeight="SemiBold"/>
								</StackPanel>
							</StackPanel>
						</Border>
						
						<StackPanel Grid.Column="1"
						            Orientation="Horizontal"
						            HorizontalAlignment="Center"
						            Margin="10,0,0,0">

							<Button Margin="10,0,0,0"
							        Width="32"
							        Height="32">
								<Image Source="{SvgImage  /Assets/download_dark.svg}"/>
							</Button>

							<Button Margin="10,0,0,0"
							        Width="32"
							        Height="32">
								<Image Source="{SvgImage /Assets/refresh_dark.svg}"/>
							</Button>
						</StackPanel>
					</Grid>
					<ScrollViewer Margin="10" Grid.Row="2">
						<ItemsControl ItemsSource="{Binding UserList}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border Classes="UserCard">
										<Grid Margin="12" ColumnDefinitions="Auto, *, Auto, Auto">
											<Border Grid.Column="0"
													Width="42" Height="42"
													CornerRadius="21"
													Background="#28A745"
													VerticalAlignment="Center">
												<TextBlock Text="{Binding Login[0]}" 
														   Foreground="White"
														   FontSize="18"
														   FontWeight="Bold"
														   HorizontalAlignment="Center"
														   VerticalAlignment="Center"/>
												</Border>

												<StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
													<StackPanel Orientation="Horizontal" Spacing="8">
														<TextBlock Text="{Binding Login}" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
														<Border IsVisible="{Binding IsAdministrator}" 
																Background="#4A90E2" CornerRadius="4" Padding="4,1">
															<TextBlock Text="ADMIN" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontWeight="Black"/>
														</Border>
													</StackPanel>
            
													<TextBlock Text="{Binding FirstName}" Foreground="#AAA" FontSize="12"/>
													<TextBlock Text="{Binding DateJoined, StringFormat='Joined: {0:d}'}" Foreground="#666" FontSize="11"/>
												</StackPanel>

												<Border Grid.Column="2" 
														IsVisible="{Binding IsAdministrator}"
														Background="#2A2A2A"
														CornerRadius="6"
														Padding="8,4"
														Margin="0,0,15,0"
														VerticalAlignment="Center">
													<StackPanel Orientation="Horizontal" Spacing="10">
														<TextBlock Text="••••••••" Foreground="#888" VerticalAlignment="Center" FontSize="12"/>
														<Button Command="{Binding CopyPasswordCommand}" 
																Classes="IconButton" Background="Transparent" Width="24" Height="24">
															<Image Source="/Assets/copy-64.png"/>
														</Button>
													</StackPanel>
												</Border>

												<StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            
													<ToggleButton IsChecked="{Binding IsActive}"
																  IsVisible="{Binding IsAdministrator}"
																  Command="{Binding ChangeActiveUserCommand}"
																  Background="Transparent" BorderThickness="0">
														<Panel>
															<Image Source="/Assets/toggle-on-64.png" Width="20" IsVisible="{Binding IsActive}"/>
															<Image Source="/Assets/toggle-off-64.png" Width="20" IsVisible="{Binding !IsActive}"/>
														</Panel>
													</ToggleButton>

													<Button Command="{Binding EditCommand}"
															Classes="IconButton" Background="#34C759"
															IsVisible="{Binding IsAdministrator}">
														<Image Source="/Assets/edit-user-64.png"/>
													</Button>

													<Button Command="{Binding DeleteCommand}"
															Classes="IconButton" Background="#FF3B30"
															IsVisible="{Binding IsAdministrator}">
														<Image Source="/Assets/remove-64.png"/>
													</Button>
												</StackPanel>
											</Grid>
										</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>
				</Grid>
			</TabItem>
        </TabControl>
    </Grid>
</UserControl>
