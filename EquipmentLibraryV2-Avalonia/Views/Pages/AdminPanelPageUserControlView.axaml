<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:vm="using:EquipmentLibraryV2_Avalonia.ViewModels.Pages"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:AdminPanelPageUserControlViewModel"
             x:Class="EquipmentLibraryV2_Avalonia.Views.Pages.AdminPanelPageUserControlView">
	
	<UserControl.Styles>
		<StyleInclude Source="/Styles/UserCardStyles.axaml"/>
		<StyleInclude Source="/Styles/ModernStyles.axaml"/>
	</UserControl.Styles>

	<Grid>
		<Grid	Margin="10" 
				RowDefinitions="Auto, Auto, *" 
				ZIndex="2">

			<Grid	Grid.Row="0" 
					HorizontalAlignment="Right" 
					VerticalAlignment="Top" 
					ColumnDefinitions="Auto, Auto">
				<StackPanel	Grid.Column="1"
		  					Orientation="Horizontal"
		  					HorizontalAlignment="Center"
		  					Margin="10,0,0,0">

					<Button Height="34"
					        Classes="modernPrimary"
					        Cursor="Hand"
					        Padding="12,0" BorderThickness="0"
                            HorizontalAlignment="Left">
                    	<StackPanel Orientation="Horizontal" Spacing="6">
                    	    <Path Data="M10 2v6h6v2h-6v6H8v-6H2V8h6V2z"
                    	          Fill="White" Stretch="Uniform" Width="14" Height="14"/>
                    	    <TextBlock Text="Добавить" FontSize="13" FontWeight="SemiBold"
                    	               VerticalAlignment="Center"/>
                    	</StackPanel>
                    	<Button.Flyout>
                    	    <Flyout Placement="Bottom">
                    	        <StackPanel Spacing="2" MinWidth="160">
                    	            <Button Classes="modernFlyoutItem"
                    	                    Command="{Binding AddUserCommand}">
                    	                <StackPanel Orientation="Horizontal" Spacing="8">
                    	                    <TextBlock Text="Добавить пользователя" FontSize="13"/>
                    	                </StackPanel>
                    	            </Button>
                    	        </StackPanel>
                    	    </Flyout>
                    	</Button.Flyout>
					</Button>
		  		</StackPanel>
			</Grid>
		</Grid>

        <TabControl Margin="5">
			<TabItem Header="Users" Foreground="White">
				<Grid RowDefinitions="Auto, Auto, *">
					<Grid Grid.Row="0" 
						   HorizontalAlignment="Center" 
						   VerticalAlignment="Top" >
						<Border CornerRadius="20"
						        Background="#8E9198"
						        Padding="20,12">
							<StackPanel Orientation="Vertical"
							            HorizontalAlignment="Center"
							            Spacing="8">
								<TextBox Width="280"
								         Height="38"
								         PlaceholderText="Search"
								         HorizontalAlignment="Center"
								         VerticalContentAlignment="Center"
								         Text="{Binding SearchText, Mode=TwoWay}"
								         Margin="0"
								         CornerRadius="14"
								         BorderThickness="1.5"
								         BorderBrush="#B0B3B8"
								         FontSize="15"/>
								<StackPanel Orientation="Horizontal"
								            HorizontalAlignment="Center"
								            Spacing="15">
									<StackPanel Orientation="Horizontal" 
									            Spacing="10">
										<CheckBox Content="Активные" 
										          IsChecked="{Binding ShowActiveUsers}"/>
										<CheckBox Content="Неактивные" 
										          IsChecked="{Binding ShowInactiveUsers}"/>
									</StackPanel>
									<Button Content="Сбросить"
									        VerticalContentAlignment="Center"
									        HorizontalContentAlignment="Center"
									        Foreground="White"
									        Background="#3A3A3A"
									        BorderBrush="#555"
									        BorderThickness="1"
									        CornerRadius="6"
									        Command="{Binding ResetFiltersCommand}"
									        Height="30"
									        Width="100"
									        FontSize="13"
									        FontWeight="SemiBold"/>
								</StackPanel>
							</StackPanel>
						</Border>
					</Grid>
					<Grid Grid.Row="2">
						<ScrollViewer Margin="10">
							<ItemsControl ItemsSource="{Binding UserList}">
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Border Classes="UserCard">
											<Grid Margin="12" ColumnDefinitions="Auto, *, Auto, Auto">
												<Border Grid.Column="0"
														Width="42" Height="42"
														CornerRadius="21"
														Background="#28A745"
														VerticalAlignment="Center">
													<TextBlock Text="{Binding AvatarChar}" 
															   Foreground="White"
															   FontSize="18"
															   FontWeight="Bold"
															   HorizontalAlignment="Center"
															   VerticalAlignment="Center"/>
													</Border>

													<StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
														<StackPanel Orientation="Horizontal" Spacing="8">
															<TextBlock Text="{Binding Login}" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
															<Border Background="#4A90E2" CornerRadius="4" Padding="4,1">
																<TextBlock Text="ADMIN" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontWeight="Black"/>
															</Border>
														</StackPanel>
	            
														<TextBlock Text="{Binding FirstName}" Foreground="#AAA" FontSize="12"/>
														<TextBlock Text="{Binding DateJoined, StringFormat='Joined: {0}'}" Foreground="#666" FontSize="11"/>
													</StackPanel>

													<Border Grid.Column="2" 
															Background="#2A2A2A"
															CornerRadius="6"
															Padding="8,4"
															Margin="0,0,15,0"
															VerticalAlignment="Center">
														<StackPanel Orientation="Horizontal" Spacing="10">
															<TextBlock Text="••••••••" Foreground="#888" VerticalAlignment="Center" FontSize="12"/>
															<Button Command="{Binding CopyPasswordCommand}" 
																	Classes="action" Background="Transparent" Width="24" Height="24">
																<Image Source="/Assets/copy-64.png"/>
															</Button>
														</StackPanel>
													</Border>

													<StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
														<ToggleButton IsChecked="{Binding IsActive}"
																	  Command="{Binding ChangeActiveUserCommand}"
																	  Classes="action isActive">
															<Panel>
																<Image Source="/Assets/toggle-on-64.png" Width="20" IsVisible="{Binding IsActive}"/>
																<Image Source="/Assets/toggle-off-64.png" Width="20" IsVisible="{Binding !IsActive}"/>
															</Panel>
														</ToggleButton>

														<Button Command="{Binding EditCommand}"
																Classes="action edit" Background="#34C759">
															<Image Source="/Assets/edit-user-64.png"/>
														</Button>

														<Button Command="{Binding DeleteCommand}"
																Classes="action delete" Background="#FF3B30">
															<Image Source="/Assets/remove-64.png"/>
														</Button>
													</StackPanel>
												</Grid>
											</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</ScrollViewer>
					
						<Grid Grid.Row="0" IsVisible="{Binding IsLoading}"
						      HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
							<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
								<ProgressBar IsIndeterminate="True" Width="200" Height="6"/>
								<TextBlock Text="Загрузка..." Foreground="#888" FontSize="13" HorizontalAlignment="Center"/>
							</StackPanel>
						</Grid>
					</Grid>
				</Grid>
			</TabItem>
        </TabControl>
    </Grid>
</UserControl>
