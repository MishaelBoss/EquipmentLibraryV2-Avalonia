<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:vm="using:EquipmentLibraryV2_Avalonia.ViewModels.Pages"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:AdminPanelPageUserControlViewModel"
             x:Class="EquipmentLibraryV2_Avalonia.Views.Pages.AdminPanelPageUserControlView">

    <UserControl.Styles>
        <StyleInclude Source="/Styles/UserCardStyles.axaml"/>

        <Style Selector="FlyoutPresenter">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style Selector="Button.FlyoutItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CED0D6"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.FlyoutItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#3A3A3A"/>
        </Style>
        <Style Selector="Button.FlyoutItem:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#2E2E2E"/>
        </Style>

        <Style Selector="Button.ToolbarBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.ToolbarBtn:pointerover">
            <Setter Property="Background" Value="#3A3A3A"/>
        </Style>
        <Style Selector="Button.ToolbarBtn:pressed">
            <Setter Property="Background" Value="#2E2E2E"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <TabControl Margin="5">
            <TabItem Header="Пользователи" Foreground="#CED0D6" FontSize="13">
                <Grid RowDefinitions="Auto, *">
                    <!-- Toolbar -->
                    <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,8,0,0">
                        <!-- Add button with dropdown -->
                        <Button Grid.Column="0" x:Name="AddButton" Height="34"
                                Background="#28A745" Foreground="White"
                                CornerRadius="6" Cursor="Hand"
                                Padding="12,0" BorderThickness="0"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Path Data="M10 2v6h6v2h-6v6H8v-6H2V8h6V2z"
                                      Fill="White" Stretch="Uniform" Width="14" Height="14"/>
                                <TextBlock Text="Добавить" FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Path Data="M4 6l4 4 4-4"
                                      Fill="White" Stretch="Uniform" Width="10" Height="10"
                                      VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <StackPanel Spacing="2" MinWidth="160">
                                        <Button Classes="FlyoutItem"
                                                Command="{Binding AddUserCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Path Data="M16 0c8.837 0 16 7.163 16 16s-7.163 16-16 16S0 24.837 0 16 7.163 0 16 0zm0 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8zm0 2a2 2 0 1 1 0 4 2 2 0 0 1 0-4zm-6 12c0-3.314 2.686-6 6-6s6 2.686 6 6H10z"
                                                      Fill="#888" Stretch="Uniform" Width="16" Height="16"/>
                                                <TextBlock Text="Добавить пользователя" FontSize="13"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <!-- Right toolbar buttons -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                            <Button Classes="ToolbarBtn">
                                <Path Data="M7 0C3.14 0 0 3.14 0 7s3.14 7 7 7 7-3.14 7-7-3.14-7-7-7zm0 11.9c-2.71 0-4.9-2.19-4.9-4.9s2.19-4.9 4.9-4.9 4.9 2.19 4.9 4.9-2.19 4.9-4.9 4.9zm1-6.9v2.59l3.27 1.98-.54.86-3.73-2.27V5z"
                                      Fill="#888" Stretch="Uniform" Width="18" Height="18"/>
                            </Button>
                            <Button Classes="ToolbarBtn">
                                <Path Data="M12 2A10 10 0 0 0 2 12h3a7 7 0 0 1 12-4.5V10h4V2l-2.3 2.3A9.96 9.96 0 0 0 12 2zm0 18a10 10 0 0 0 10-10h-3a7 7 0 0 1-12 4.5V14H4v8l2.3-2.3A9.96 9.96 0 0 0 12 20z"
                                      Fill="#888" Stretch="Uniform" Width="18" Height="18"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Search and filters -->
                    <Grid Grid.Row="1" RowDefinitions="Auto, *">
                        <Border Grid.Row="0" CornerRadius="20" Background="#2B2D31"
                                Padding="20,12" Margin="0,12,0,0">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="8">
                                <TextBox Width="280" Height="36"
                                         PlaceholderText="Поиск по логину или имени..."
                                         HorizontalAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding SearchText, Mode=TwoWay}"
                                         CornerRadius="14"
                                         BorderThickness="1.5"
                                         BorderBrush="#444"
                                         Background="#1E1E1E"
                                         Foreground="White"
                                         FontSize="14"
                                         CaretBrush="White"
                                         PlaceholderForeground="#666"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <CheckBox Content="Активные"
                                                  IsChecked="{Binding ShowActiveUsers}"
                                                  Foreground="#CED0D6"/>
                                        <CheckBox Content="Неактивные"
                                                  IsChecked="{Binding ShowInactiveUsers}"
                                                  Foreground="#CED0D6"/>
                                    </StackPanel>
                                    <Button Content="Сбросить"
                                            VerticalContentAlignment="Center"
                                            HorizontalContentAlignment="Center"
                                            Foreground="#CED0D6"
                                            Background="#3A3A3A"
                                            BorderBrush="#555"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Command="{Binding ResetFiltersCommand}"
                                            Height="30" Width="100"
                                            FontSize="13" FontWeight="SemiBold"
                                            Cursor="Hand"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- User list -->
                        <Grid Grid.Row="1">
                            <ScrollViewer Margin="10">
                                <ItemsControl ItemsSource="{Binding UserList}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Classes="UserCard">
                                                <Grid Margin="12" ColumnDefinitions="Auto, *, Auto, Auto">
                                                    <!-- Avatar -->
                                                    <Border Grid.Column="0"
                                                            Width="42" Height="42"
                                                            CornerRadius="21"
                                                            Background="#28A745"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Login[0]}"
                                                                   Foreground="White"
                                                                   FontSize="18" FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <!-- Info -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{Binding Login}"
                                                                       Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding FirstName}"
                                                                   Foreground="#AAA" FontSize="12"/>
                                                        <TextBlock Text="{Binding DateJoined, StringFormat='Регистрация: {0}'}"
                                                                   Foreground="#666" FontSize="11"/>
                                                    </StackPanel>

                                                    <!-- Password -->
                                                    <Border Grid.Column="2"
                                                            Background="#2A2A2A"
                                                            CornerRadius="6"
                                                            Padding="8,4"
                                                            Margin="0,0,15,0"
                                                            VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                                            <TextBlock Text="••••••••" Foreground="#888" VerticalAlignment="Center" FontSize="12"/>
                                                            <Button Command="{Binding CopyPasswordCommand}"
                                                                    Classes="action" Background="Transparent" Width="24" Height="24">
                                                                <Path Data="M4 0h12v2H4V0zm0 4h12v2H4V4zm0 4h8v2H4V8zm0 4h12v2H4v-2z"
                                                                      Fill="#888" Stretch="Uniform" Width="16" Height="16"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Actions -->
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                        <ToggleButton IsChecked="{Binding IsActive}"
                                                                      Command="{Binding ChangeActiveUserCommand}"
                                                                      Classes="action isActive"
                                                                      Cursor="Hand">
                                                            <Panel>
                                                                <Path Data="M16 0a8 8 0 1 1 0 16A8 8 0 0 1 16 0zm0 2a6 6 0 1 0 0 12A6 6 0 0 0 16 2zm0 2a4 4 0 1 1 0 8 4 4 0 0 1 0-8z"
                                                                      Fill="#4CAF50" Stretch="Uniform" Width="20" Height="20"
                                                                      IsVisible="{Binding IsActive}"/>
                                                                <Path Data="M16 0a8 8 0 1 1 0 16A8 8 0 0 1 16 0zm0 2a6 6 0 1 0 0 12A6 6 0 0 0 16 2z"
                                                                      Fill="#888" Stretch="Uniform" Width="20" Height="20"
                                                                      IsVisible="{Binding IsActive, Converter={x:Static BoolConverters.Not}}"/>
                                                            </Panel>
                                                        </ToggleButton>

                                                        <Button Command="{Binding EditCommand}"
                                                                Classes="action edit"
                                                                Cursor="Hand">
                                                            <Path Data="M18 0l4 4-2 2-4-4 2-2zM.48 18.27l-.47 4.18 4.23-.46L17.6 8.12l-3.73-3.73L.48 18.27z"
                                                                  Fill="White" Stretch="Uniform" Width="16" Height="16"/>
                                                        </Button>

                                                        <Button Command="{Binding DeleteCommand}"
                                                                Classes="action delete"
                                                                Cursor="Hand">
                                                            <Path Data="M6 2h8l-1 1H7L6 2zM3 4h14v1H3V4zm2 2l1 12h8l1-12H5z"
                                                                  Fill="White" Stretch="Uniform" Width="16" Height="16"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Loading overlay -->
                            <Grid IsVisible="{Binding IsLoading}"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                  Background="#80000000">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                                    <ProgressBar IsIndeterminate="True" Width="200" Height="6" Foreground="#28A745"/>
                                    <TextBlock Text="Загрузка..." Foreground="#888" FontSize="13" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
