<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:EquipmentLibraryV2_Avalonia.ViewModels.Pages"
             x:DataType="vm:WorkAreaUserControlViewModel"
             x:Class="EquipmentLibraryV2_Avalonia.Views.Pages.WorkAreaUserControlView">
    <Grid RowDefinitions="Auto, Auto" Margin="20">
        <TextBlock Grid.Row="0" Text="Рабочий стол сотрудника" FontSize="15"/>
        <Grid Grid.Row="1" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.Styles>
                <Style Selector="TextBox">
                    <Setter Property="Background" Value="#252525"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="CornerRadius" Value="2"/>
                    <Setter Property="Height" Value="35"/>
                </Style>
                <Style Selector="ComboBox">
                    <Setter Property="Background" Value="#252525"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                </Style>
            </Grid.Styles>

            <Border Grid.Column="0" Background="#1A1A1A" CornerRadius="21" Padding="20" Margin="0,0,10,0">
                <StackPanel Spacing="10">
                    <TextBlock Text="Быстрая регистрация оборудования" Foreground="White" FontSize="14" Margin="0,0,0,10"/>
            
                    <TextBlock Text="Тип объекта" Foreground="#888" FontSize="10"/>
                    <ComboBox SelectedIndex="0" 
                              ItemsSource="{Binding EquipmentTypes}"
                              SelectedItem="{Binding SelectedEquipmentType}"/>

                    <Grid ColumnDefinitions="*, *" Margin="0,10,0,0">
                        <TextBox Grid.Column="0" PlaceholderText="Наименование" Margin="0,0,5,0" VerticalContentAlignment="Center"/>
                        <TextBox Grid.Column="1" PlaceholderText="Заводской №" Margin="5,0,0,0" VerticalContentAlignment="Center"/>
                    </Grid>

                    <Button Content="Добавить в систему" 
                            Background="#4CAF50" 
                            Foreground="White" 
                            HorizontalAlignment="Stretch"
                            VerticalContentAlignment="Center"
                            HorizontalContentAlignment="Center"
                            Height="40" 
                            CornerRadius="3"
                            Margin="0,15,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" Spacing="10">
                <Border Background="#1A1A1A" Height="70" CornerRadius="4">
                    <Grid ColumnDefinitions="5, *">
                        <Border Background="#D32F2F" CornerRadius="4,0,0,4"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                            <TextBlock Text="12" FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="ПОВЕРКА ИСТЕКАЕТ (30 ДНЕЙ)" FontSize="9" Foreground="#666"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="#1A1A1A" Height="70" CornerRadius="4">
                    <Grid ColumnDefinitions="5, *">
                        <Border Background="#43A047" CornerRadius="4,0,0,4"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                            <TextBlock Text="854" FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="ВСЕГО ОБЪЕКТОВ УЧЕТА" FontSize="9" Foreground="#666"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
