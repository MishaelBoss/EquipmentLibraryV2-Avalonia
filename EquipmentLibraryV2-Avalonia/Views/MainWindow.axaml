<Window xmlns="https://github.com/avaloniaui"
        xmlns:controls="using:EquipmentLibraryV2_Avalonia"
        xmlns:converters="using:EquipmentLibraryV2_Avalonia.Converters"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EquipmentLibraryV2_Avalonia.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="650"
        Width="1000" Height="650" MinWidth="500" MinHeight="350"
        x:Class="EquipmentLibraryV2_Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Background="Transparent"
        Icon="/Assets/logo/logo.ico"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="Full"
        ExtendClientAreaTitleBarHeightHint="40"
        Title="">

	<Window.Styles>
		<Style Selector="Button.WindowButton">
			<Setter Property="Width" Value="46"/>
			<Setter Property="Height" Value="34"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
		</Style>
		<Style Selector="Button.WindowButton:pointerover">
			<Setter Property="Background" Value="#3A3A3A"/>
		</Style>
		<Style Selector="Button.WindowButton:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#3A3A3A"/>
		</Style>
		<Style Selector="Button.WindowButton.CloseButton:pointerover">
			<Setter Property="Background" Value="#E81123"/>
		</Style>
		<Style Selector="Button.WindowButton.CloseButton:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#E81123"/>
		</Style>
		<Style Selector="Button.WindowButton:pressed /template/ ContentPresenter">
			<Setter Property="Background" Value="#505050"/>
		</Style>
		<Style Selector="Button.WindowButton.CloseButton:pressed /template/ ContentPresenter">
			<Setter Property="Background" Value="#F1707A"/>
		</Style>
	</Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <converters:DoubleToGridLengthConverter x:Key="DoubleToGridLengthConverter"/>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </Window.Resources>

	<Border CornerRadius="8" Background="#000000" ClipToBounds="True" x:Name="MainBorder">
		<Grid RowDefinitions="Auto, *, Auto">
			<Grid Grid.Row="0" Height="40" Background="Transparent" ColumnDefinitions="Auto, *, Auto" WindowDecorationProperties.ElementRole="TitleBar">

				<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
					<Image Source="/Assets/logo/logo.ico" Width="18" Height="18" IsVisible="{OnPlatform True, macOS=False}"/>
				</StackPanel>

				<TextBlock Grid.Column="1"
						   Text="EquipmentLibrary"
						   FontWeight="SemiBold"
						   Foreground="#CED0D6"
						   HorizontalAlignment="Center"
						   VerticalAlignment="Center"
						   IsHitTestVisible="False"/>

				<Grid Grid.Column="2" Width="140">
					<Grid IsHitTestVisible="False" x:Name="SpacerGrid"/>

					<StackPanel Orientation="Horizontal"
								HorizontalAlignment="Right"
								x:Name="ButtonStack">
						<Button Classes="WindowButton"
								Click="Minimize_Click">
							<Panel Width="12" Height="12">
								<Rectangle Fill="#CED0D6"
										   Width="10" Height="1.5"
										   HorizontalAlignment="Center"
										   VerticalAlignment="Center"/>
							</Panel>
						</Button>
						<Button Classes="WindowButton"
								Click="MaximizeRestore_Click"
								x:Name="MaximizeRestoreButton">
							<Panel Width="12" Height="12">
								<Rectangle Stroke="#CED0D6"
										   StrokeThickness="1.5"
										   Width="10" Height="10"
										   HorizontalAlignment="Center"
										   VerticalAlignment="Center"
										   x:Name="MaximizeIcon"/>
								<Rectangle Stroke="#CED0D6"
										   StrokeThickness="1.5"
										   Width="8" Height="8"
										   HorizontalAlignment="Center"
										   VerticalAlignment="Center"
										   Margin="-1,-1,0,0"
										   x:Name="RestoreIcon"
										   IsVisible="False"/>
							</Panel>
						</Button>
						<Button Classes="WindowButton CloseButton"
								Click="Close_Click">
							<Panel Width="12" Height="12">
								<Line StartPoint="1,1" EndPoint="11,11"
									  Stroke="#CED0D6" StrokeThickness="1.5"
									  HorizontalAlignment="Center" VerticalAlignment="Center"/>
								<Line StartPoint="11,1" EndPoint="1,11"
									  Stroke="#CED0D6" StrokeThickness="1.5"
									  HorizontalAlignment="Center" VerticalAlignment="Center"/>
							</Panel>
						</Button>
					</StackPanel>
				</Grid>
			</Grid>

			<Grid Grid.Row="1" ColumnDefinitions="Auto, *">
				<Grid Grid.Column="0">
					<controls:RightBoardUserControl DataContext="{Binding RightBoardViewModel}"/>
				</Grid>

				<Border Grid.Column="1"
						Background="#2B2D31"
						CornerRadius="8"
						Margin="8, 0, 8, 8"
						ClipToBounds="True">
					<Grid>
						<ContentControl Content="{Binding CurrentPage}" ZIndex="0"/>
						<ContentControl Content="{Binding OverlayContent}" ZIndex="1"/>
						<ScrollViewer ZIndex="999" VerticalAlignment="Bottom" HorizontalAlignment="Right"
						              MaxHeight="300" Margin="12">
							<ItemsControl ItemsSource="{Binding ErrorMessages}"
							              VerticalAlignment="Bottom">
								<ItemsControl.ItemsPanel>
									<ItemsPanelTemplate>
										<StackPanel Spacing="8" VerticalAlignment="Bottom"/>
									</ItemsPanelTemplate>
								</ItemsControl.ItemsPanel>
							</ItemsControl>
						</ScrollViewer>
					</Grid>
				</Border>
			</Grid>

			<ContentControl Grid.RowSpan="3" Grid.ColumnSpan="2"
							Content="{Binding TopOverlayContent}"
							ZIndex="10"/>

			
			<Border Grid.Row="2" Grid.ColumnSpan="2"
			        Background="#000000"
			        Padding="16,0" Height="28">
				<Grid ColumnDefinitions="Auto, Auto, *, Auto">
					<Grid Grid.Column="0">
						<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" IsVisible="{Binding IsConnected}">
							<Ellipse Width="8" Height="8" Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}"/>
							<TextBlock Text="{Binding StatusNetwork}" Foreground="#888" FontSize="11"/>
						</StackPanel>
						
						<Button Background="Transparent" Command="{Binding ReturnToConnectNetworkCommand}" IsVisible="{Binding !IsConnected}">
							<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
								<Ellipse Width="8" Height="8" Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}"/>
								<TextBlock Text="{Binding StatusNetwork}" Foreground="#888" FontSize="11"/>
								<Image Source="{SvgImage /Assets/refresh.svg}" Width="12" Height="12"/>
							</StackPanel>
						</Button>
					</Grid>
					<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="16,0,0,0"
					            x:Name="RefreshIndicator" Opacity="0" IsVisible="False">
						<TextBlock Text="✓" Foreground="#4CAF50" FontSize="12" FontWeight="Bold"/>
						<TextBlock Text="Обновлено" Foreground="#4CAF50" FontSize="11"/>
					</StackPanel>
					<Grid Grid.Column="3">
						<Button Background="Transparent" Command="{Binding AboutCommand}" IsVisible="{Binding !IsNewVerion}">
							<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
								<TextBlock VerticalAlignment="Center"
										   Foreground="#666" FontSize="11" FontWeight="SemiBold">
									<Run Text="{Binding Version}"/>
								</TextBlock>
							</StackPanel>
						</Button>

						<Button Background="Transparent" 
								IsVisible="{Binding IsNewVerion}" 
								Command="{Binding UpdateCommand}"
								CommandParameter="{Binding $self}">
							<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
								<Image Source="{SvgImage /Assets/update.svg}" Width="12" Height="12"/>
								<TextBlock VerticalAlignment="Center"
								   Foreground="#666" FontSize="11" FontWeight="SemiBold">
									<Run Text="{Binding Version}"/>
								</TextBlock>
							</StackPanel>
						</Button>
					</Grid>
				</Grid>
			</Border>
		</Grid>
	</Border>
</Window>
