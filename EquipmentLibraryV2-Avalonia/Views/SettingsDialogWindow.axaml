<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:EquipmentLibraryV2_Avalonia.ViewModels"
        xmlns:settings="clr-namespace:EquipmentLibraryV2_Avalonia.Views.Settings"
        xmlns:settingsVm="clr-namespace:EquipmentLibraryV2_Avalonia.ViewModels.Settings"
        x:DataType="vm:SettingsDialogWindowViewModel"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        Width="1000" Height="620"
        MinWidth="800"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="#000000"
        x:Class="EquipmentLibraryV2_Avalonia.SettingsDialogWindow"
        Title="Настройки">
    
    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type settingsVm:LoggingViewModel}">
            <settings:LoggingView/>
        </DataTemplate>
    </Window.DataTemplates>

    <Grid RowDefinitions="*, Auto">        
        <Grid Grid.Row="0" ColumnDefinitions="250, *">
            <!-- ЛЕВАЯ ПАНЕЛЬ: Навигация в темном стиле -->
            <Grid Grid.Column="0" RowDefinitions="Auto, *" Background="#000000" Margin="0,16,0,0">
                <!-- Поиск по настройкам -->
                <TextBox Grid.Row="0" 
                         Margin="16,4" 
                         Watermark="Search" 
                         Height="32" 
                         CornerRadius="6" 
                         Background="#1F2023" 
                         BorderBrush="#3D3D42"
                         Foreground="White"/>
                
                <!-- Список категорий -->
                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding Pages}" 
                         SelectedItem="{Binding SelectedPage}" 
                         Background="Transparent" 
                         BorderThickness="0" 
                         Margin="0,12,0,0">
                    
                    <ListBox.Styles>
                        <!-- Базовый стиль для всех элементов списка -->
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="16,10"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Foreground" Value="#9E9EB0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="CornerRadius" Value="6"/>
                            <Setter Property="Margin" Value="8,2"/>
                        </Style>
                        <!-- Эффект наведения -->
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#1A1A1C"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                        <!-- Выбранный элемент (как "Логирование") -->
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="#1F2023"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </ListBox.Styles>
                    
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <Border Grid.Column="1" 
                    Background="#1F2023" 
                    CornerRadius="12" 
                    Margin="0,16,16,16">
                
                <Grid RowDefinitions="Auto, *" Margin="24">
                    <TextBlock Grid.Row="0" 
                               Text="{Binding SelectedPage.Title}" 
                               FontSize="18" 
                               FontWeight="SemiBold" 
                               Foreground="White" 
                               Margin="0,0,0,16"/>
                    
                    <ContentControl Grid.Row="1" 
                                    Content="{Binding SelectedPage.ViewModel}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- НИЖНЯЯ ПАНЕЛЬ: Кнопки управления -->
        <Border Grid.Row="1" Background="#000000" Padding="16,12,24,16">
            <Grid ColumnDefinitions="Auto, *">                
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                    <Button Content="ОК" Command="{Binding OkCommand}" CommandParameter="{Binding $parent[Window]}" IsDefault="True" Width="85" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Background="#1F2023" BorderBrush="#3D3D42" BorderThickness="1" Foreground="White" CornerRadius="6"/>
                    <Button Content="Отмена" Command="{Binding CancelCommand}" CommandParameter="{Binding $parent[Window]}" IsCancel="True" Width="85" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Background="Transparent" BorderBrush="#3D3D42" BorderThickness="1" Foreground="#9E9EB0" CornerRadius="6"/>
                    <Button Content="Применить" IsEnabled="False" Width="105" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Background="Transparent" BorderBrush="#1F2023" BorderThickness="1" Foreground="#4D4D52" CornerRadius="6"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
