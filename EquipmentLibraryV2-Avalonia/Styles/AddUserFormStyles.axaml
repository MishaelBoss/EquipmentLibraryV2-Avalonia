<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="Border.FormCard">
        <Setter Property="Background" Value="#2E2E2E"/>
        <Setter Property="BorderBrush" Value="#444"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BoxShadow" Value="0 8 24 0 #60000000"/>
    </Style>

    <Style Selector="TextBlock.FieldLabel">
        <Setter Property="Foreground" Value="#999"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Margin" Value="4,0,0,6"/>
    </Style>

    <Style Selector="TextBox.ModernInput">
        <Setter Property="Background" Value="#3A3A3A"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#444"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    
    <Style Selector="TextBox.ModernInput:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="#555"/>
        <Setter Property="Background" Value="#404040"/>
    </Style>
    
    <Style Selector="TextBox.ModernInput:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="#28A745"/>
        <Setter Property="Background" Value="#3A3A3A"/>
    </Style>

    <Style Selector="ComboBox.ModernSelect">
        <Setter Property="Background" Value="#3A3A3A"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#444"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="MinHeight" Value="40"/>
    </Style>

    <Style Selector="ComboBox.ModernSelect ComboBoxItem">
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style Selector="ComboBox.ModernSelect:pointerover /template/ Border#Layer_1">
        <Setter Property="Background" Value="#404040"/>
        <Setter Property="BorderBrush" Value="#555"/>
    </Style>

    <Style Selector="Button.PrimaryButton">
        <Setter Property="Background" Value="#28A745"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Height" Value="45"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="16"/>
    </Style>
    
    <Style Selector="Button.PrimaryButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#218838"/>
    </Style>
</Styles>
